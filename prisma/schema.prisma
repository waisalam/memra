generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  plan          String    @default("free")
  memoriesCount Int       @default(0)
  apiKeys          ApiKey[]
  memories         Memory[]  @relation("MemoryAccount")
  accounts         Account[]
  sessions         Session[]
  apiLogs          ApiLog[]
  contextSessions  ContextSession[]
  apiUsage         ApiUsage[]
  extensionSessions ExtensionSession[] @relation("ExtensionSessions")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ApiKey {
  id        String    @id @default(cuid())
  key       String    @unique @default(cuid())
  name      String
  userId    String
  keyType   String    @default("memory")
  user      User      @relation(fields: [userId], references: [id])
  createdAt DateTime  @default(now())
  lastUsed  DateTime?
  isActive  Boolean   @default(true)
}

model Memory {
  id        String   @id @default(cuid())
  accountId String
  userId    String
  agentId   String   @default("default")
  role      String
  content   String
  createdAt DateTime @default(now())
  account   User     @relation("MemoryAccount", fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, userId])
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  phone     String?
  message   String   @db.Text
  plan      String   @default("enterprise")
  status    String   @default("new")
  createdAt DateTime @default(now())

  @@index([status])
  @@index([createdAt])
}

model ApiLog {
  id         String   @id @default(cuid())
  userId     String
  endpoint   String
  method     String
  agentId    String?
  statusCode Int
  latencyMs  Int
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([createdAt])
}

model ContextSession {
  id           String   @id @default(cuid())
  userId       String
  title        String
  tool         String   @default("other")
  messages     Json
  summary      String?  @db.Text
  resumePrompt String?  @db.Text
  tokenCount   Int      @default(0)
  messageCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model ApiUsage {
  id        String @id @default(cuid())
  userId    String
  month     String
  callCount Int    @default(0)
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@index([userId, month])
}

model ExtensionSession {
  id             String             @id @default(cuid())
  accountId      String
  sessionHash    String             @unique
  tool           String
  title          String
  projectId      String?
  workspacePath  String?
  messages       Json
  messageCount   Int                @default(0)
  tokenCount     Int                @default(0)
  summary        String?            @db.Text
  resumePrompt   String?            @db.Text
  isActive       Boolean            @default(true)
  startedAt      DateTime           @default(now())
  lastSavedAt    DateTime           @updatedAt
  account        User               @relation("ExtensionSessions", fields: [accountId], references: [id])
  extensionMessages ExtensionMessage[]

  @@index([accountId, lastSavedAt])
  @@index([accountId, isActive])
  @@index([accountId, projectId])
  @@index([sessionHash])
}

model ExtensionMessage {
  id        String           @id @default(cuid())
  sessionId String
  accountId String
  role      String
  content   String           @db.Text
  tool      String
  tokens    Int              @default(0)
  savedAt   DateTime         @default(now())
  session   ExtensionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([accountId, savedAt])
}
